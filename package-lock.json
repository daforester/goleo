{
  "name": "goleo-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "goleo-monorepo",
      "workspaces": [
        "bridge",
        "cli/npm"
      ]
    },
    "bridge": {
      "name": "@goleo/bridge",
      "version": "0.3.0",
      "license": "MIT",
      "devDependencies": {
        "typescript": "^5.3.0"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "cli/npm": {
      "name": "@goleo/cli",
      "version": "0.3.0",
      "license": "MIT",
      "bin": {
        "goleo": "bin/goleo.js"
      },
      "engines": {
        "node": ">=18"
      },
      "optionalDependencies": {
        "@goleo/cli-darwin-arm64": "0.3.0",
        "@goleo/cli-darwin-x64": "0.3.0",
        "@goleo/cli-linux-arm64": "0.3.0",
        "@goleo/cli-linux-x64": "0.3.0",
        "@goleo/cli-win32-arm64": "0.3.0",
        "@goleo/cli-win32-x64": "0.3.0"
      }
    },
    "node_modules/@goleo/bridge": {
      "resolved": "bridge",
      "link": true
    },
    "node_modules/@goleo/cli": {
      "resolved": "cli/npm",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    }
  }
}
