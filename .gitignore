.idea/
*.exe
/goleo
node_modules/
dist/
prebuilt/

# Generated by cli/npm/copy-source.js (a copy of runtime/ + go.mod + vendor/ +
# bridge/), regenerated on `npm publish` (prepublishOnly) and by scripts/setup.*.
# Not source — do not commit (it duplicates the repo and drifts).
/cli/npm/goleo/
# CLI binary built by scripts/setup.* / build-binaries.js (bin/goleo.js is source).
/cli/npm/bin/goleo

# Spike verify apps embed a committed test fixture under frontend/dist (the path
# the runtime's asset server expects). Re-include it despite the dist/ rule above,
# or the //go:embed fails on a fresh checkout (CI) while passing locally.
!spikes/**/frontend/dist/
!spikes/**/frontend/dist/**
