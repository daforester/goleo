{
  "name": "goleo-monorepo",
  "private": true,
  "workspaces": [
    "bridge",
    "create-goleo-app",
    "cli/npm"
  ],
  "scripts": {
    "build:bridge": "npm run build -w bridge",
    "build:create-app": "npm run build -w create-goleo-app",
    "build:all": "npm run build:bridge && npm run build:create-app",
    "publish:bridge": "npm publish -w bridge",
    "publish:create-app": "npm publish -w create-goleo-app",
    "publish:cli": "npm publish -w cli/npm",
    "publish:all": "npm run publish:bridge && npm run publish:create-app && npm run publish:cli"
  }
}
