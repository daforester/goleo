{
  "name": "@goleo/cli",
  "version": "0.1.0",
  "description": "Goleo CLI — build cross-platform apps with Go + web tech",
  "type": "module",
  "bin": {
    "goleo": "./bin/goleo.js"
  },
  "scripts": {
    "postinstall": "node ./install.js",
    "prepublishOnly": "node ./build-binaries.js && node ./copy-source.js",
    "build": "node ./build-binaries.js && node ./copy-source.js"
  },
  "files": [
    "bin",
    "goleo",
    "install.js",
    "copy-source.js",
    "platform.json"
  ],
  "optionalDependencies": {
    "@goleo/cli-darwin-arm64": "0.1.0",
    "@goleo/cli-darwin-x64": "0.1.0",
    "@goleo/cli-linux-arm64": "0.1.0",
    "@goleo/cli-linux-x64": "0.1.0",
    "@goleo/cli-win32-arm64": "0.1.0",
    "@goleo/cli-win32-x64": "0.1.0"
  },
  "keywords": ["goleo", "go", "desktop", "mobile", "cross-platform", "cli"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daforester/goleo.git"
  }
}
